<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns="http://java.sun.com/xml/ns/javaee" xmlns:web="http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd"
	xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-app_3_0.xsd"
	id="WebApp_ID" version="3.0">
	<display-name>vedantu-ext-cmds-uploader</display-name>
	<context-param>
		<param-name>log4j-config</param-name>
		<param-value>WEB-INF/log4j.xml</param-value>
	</context-param>
	<resource-ref>
		<description>Vedantu Local Database</description>
		<res-ref-name>jdbc/vedantu</res-ref-name>
		<res-type>javax.sql.DataSource</res-type>
		<res-auth>Container</res-auth>
		<res-sharing-scope>Unshareable</res-sharing-scope>
	</resource-ref>

	<!-- <filter> <filter-name>AuthenticationFilter</filter-name> <filter-class>com.vedantu.ext.cmds.filters.AuthenticationFilter</filter-class> 
		</filter> <filter-mapping> <filter-name>AuthenticationFilter</filter-name> 
		<url-pattern>/*</url-pattern> </filter-mapping> -->


	<filter>
		<filter-name>AuthenticationFilterNew</filter-name>
		<filter-class>com.vedantu.ext.cmds.filters.AuthenticationFilterNew</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>AuthenticationFilterNew</filter-name>
		<url-pattern>/*</url-pattern>
	</filter-mapping>



	<servlet>
		<description>Landing Page Servlet</description>
		<display-name>LandingPageServlet</display-name>
		<servlet-name>LandingPageServlet</servlet-name>
		<servlet-class>com.vedantu.ext.cmds.servlets.LandingPageServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>LandingPageServlet</servlet-name>
		<url-pattern>/landingPage</url-pattern>
	</servlet-mapping>

	<welcome-file-list>
		<welcome-file>index.jsp</welcome-file>
	</welcome-file-list>

	<error-page>
		<error-code>404</error-code>
		<location>/404.jsp</location>
	</error-page>
	<error-page>
		<error-code>500</error-code>
		<location>/500.jsp</location>
	</error-page>
	<error-page>
		<exception-type>java.lang.Throwable</exception-type>
		<location>/500.jsp</location>
	</error-page>
	<error-page>
		<exception-type>java.lang.Exception</exception-type>
		<location>/500.jsp</location>
	</error-page>
	<error-page>
		<exception-type>java.sql.SQLException</exception-type>
		<location>/500.jsp</location>
	</error-page>
	<error-page>
		<exception-type>javax.servlet.ServletException</exception-type>
		<location>/errorPage.jsp</location>
	</error-page>

</web-app>
