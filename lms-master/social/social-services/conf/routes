# Routes
# This file defines all application routes (Higher priority routes first)
# ~~~~

# Home page
GET     /                           controllers.Application.index()

# Map static resources from the /public folder to the /assets URL path
GET     /assets/*file               controllers.Assets.at(path="/public", file)

#ping
GET    /application/ping                           controllers.Application.ping()

# this is common controller across all services and will provide information about currently deployed build
POST	/sysinfo/get                              controllers.SysInfo.getInfo()

# social api's
POST 	/socials/view								controllers.Socials.view()
POST 	/socials/upVote								controllers.Socials.upVote()
POST 	/socials/follow								controllers.Socials.follow()
POST 	/socials/unFollow							controllers.Socials.unFollow()
POST 	/socials/getFollowers						controllers.Socials.getFollowers()
POST 	/socials/getVoters							controllers.Socials.getVoters()
POST 	/socials/getViewers							controllers.Socials.getViewers()
POST 	/socials/completed							controllers.Socials.completed()
POST    /socials/sendEmail                          controllers.Socials.sendEmail()
