# Routes
# This file defines all application routes (Higher priority routes first)
# ~~~~

# Home page
GET     /                           controllers.Application.index()

# Map static resources from the /public folder to the /assets URL path
GET     /assets/*file               controllers.Assets.at(path="/public", file)

# this is common controller across all services and will provide information about currently deployed build
POST	/sysinfo/get                              controllers.SysInfo.getInfo()

#ping
GET    /application/ping                           controllers.Application.ping()

POST    /boards/uploadGlobalBoards        controllers.Boards.uploadGlobalBoards()
POST    /boards/uploadConsumerBoards      controllers.Boards.uploadConsumerBoards()
POST    /boards/uploadOrgBoards           controllers.Boards.uploadOrgBoards()
POST    /boards/getChildren               controllers.Boards.getChildren()
POST    /boards/getTargets                controllers.Boards.getTargets()
POST    /boards/getTreesOfBoards          controllers.Boards.getTreesOfBoards()
POST    /boards/delete			  controllers.Boards.removeBoardFromTree()
