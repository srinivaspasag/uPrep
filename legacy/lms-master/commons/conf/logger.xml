<configuration>
  <!-- Errors were reported during translation. -->
  <!-- No root logger configuration was found -->
  <appender name="file" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <!--See http://logback.qos.ch/manual/appenders.html#RollingFileAppender-->
    <!--and http://logback.qos.ch/manual/appenders.html#TimeBasedRollingPolicy-->
    <!--for further documentation-->
    <File>logs/${LOG_FILE_NAME}.log</File>
    <encoder>
      <!-- pattern>%5p [%t] [%d] [%r] (%F:%L) - %m%n</pattern -->
      <pattern>%-5level [%thread] [%d] [%logger{0}] - %msg%n</pattern>
      <!-- pattern>%d %-5level [%thread] %logger{0}: %msg%n</pattern -->
    </encoder>
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
	<!-- daily rollover -->      
	<fileNamePattern>logs/${LOG_FILE_NAME}.log.%d{yyyy-MM-dd}.gz</fileNamePattern>
	<!-- keep 3 days' worth of history -->
	<maxHistory>3</maxHistory>
    </rollingPolicy>
  </appender>
  <logger name="net.sf.ehcache" level="ERROR">
    <appender-ref ref="file"/>
  </logger>
  <logger name="org.apache.hadoop" level="ERROR">
    <appender-ref ref="file"/>
  </logger>
  <logger name="org.elasticsearch" level="ERROR">
    <appender-ref ref="file"/>
  </logger>
  <logger name="net.spy.memcached" level="ERROR">
    <appender-ref ref="file"/>
  </logger>
  <logger name="netty.channel" level="ERROR">
    <appender-ref ref="file"/>
  </logger>
  <logger name="org.apache.commons" level="ERROR">
    <appender-ref ref="file"/>
  </logger>
  <logger name="org.restlet" level="INFO">
    <appender-ref ref="file"/>
  </logger>
  <logger name="play" level="INFO">
    <appender-ref ref="file"/>
  </logger>
  <logger name="com.ning.http" level="ERROR">
    <appender-ref ref="file"/>
  </logger>
  <logger name="com.amazonaws" level="ERROR">
    <appender-ref ref="file"/>
  </logger>
  <logger name="org.apache.http.wire" level="ERROR">
    <appender-ref ref="file"/>
  </logger>
  <root level="DEBUG">
    <appender-ref ref="file" />
  </root>
</configuration>
